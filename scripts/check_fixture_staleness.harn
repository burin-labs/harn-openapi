// Warn or fail when the pinned Notion fixture metadata is stale.
//
// Default target:
//   tests/fixtures/notion.openapi.json.meta.toml
//
// Optional argv[0] overrides the metadata path for tests or one-off checks.
// Optional argv[1] overrides the fixture path; otherwise it is derived from
// the metadata path by stripping ".meta.toml".
const _DEFAULT_META_REL_PATH = "tests/fixtures/notion.openapi.json.meta.toml"

const _WARN_AFTER_DAYS = 90

const _FAIL_AFTER_DAYS = 180

fn _repo_root() -> string {
  return source_dir() + "/.."
}

fn _default_meta_path() -> string {
  return _repo_root() + "/" + _DEFAULT_META_REL_PATH
}

fn _current_branch(harness: Harness) -> string {
  const github_ref = harness.env.get("GITHUB_REF_NAME")
  if github_ref != nil && github_ref != "" {
    return github_ref
  }
  const result = try {
    harness.process.spawn_captured(
      {cmd: "git", args: ["branch", "--show-current"], cwd: _repo_root()},
    )
  } catch (e) {
    return ""
  }
  if result.success {
    return result.stdout.trim()
  }
  return ""
}

fn _fixture_age_days(harness: Harness, captured_at: string) -> int {
  const captured_ts = date_parse(captured_at)
  const now_ts = harness.clock.timestamp()
  return floor((now_ts - captured_ts) / 86400.0)
}

fn _fixture_path_for_meta(meta_path: string) -> string {
  const suffix = ".meta.toml"
  if meta_path.ends_with(suffix) {
    return substring(meta_path, 0, len(meta_path) - len(suffix))
  }
  return meta_path + ".json"
}

fn _require_fixture_integrity(
  harness: Harness,
  meta_path: string,
  fixture_path: string,
  meta: dict,
) {
  if !harness.fs.exists(fixture_path) {
    throw "check_fixture_staleness: missing fixture file " + fixture_path
  }
  const expected_hash = meta.get("sha256")
  if expected_hash == nil || expected_hash == "" {
    throw "check_fixture_staleness: metadata missing sha256"
  }
  const expected_size = meta.get("byte_size")
  if expected_size == nil {
    throw "check_fixture_staleness: metadata missing byte_size"
  }
  const body = harness.fs.read_text(fixture_path)
  const actual_hash = sha256(body)
  if actual_hash != expected_hash {
    throw "check_fixture_staleness: sha256 mismatch for "
      + fixture_path
      + " (metadata "
      + meta_path
      + ")"
  }
  const actual_size = harness.fs.stat(fixture_path).size
  if actual_size != expected_size {
    throw "check_fixture_staleness: byte_size mismatch for "
      + fixture_path
      + " (expected "
      + to_string(expected_size)
      + ", got "
      + to_string(actual_size)
      + ")"
  }
}

pipeline default() {
  const meta_path = if len(argv) > 0 {
    argv[0]
  } else {
    _default_meta_path()
  }
  if !harness.fs.exists(meta_path) {
    throw "check_fixture_staleness: missing metadata file " + meta_path
  }
  const fixture_path = if len(argv) > 1 {
    argv[1]
  } else {
    _fixture_path_for_meta(meta_path)
  }
  const meta = toml_parse(harness.fs.read_text(meta_path))
  _require_fixture_integrity(harness, meta_path, fixture_path, meta)
  const captured_at = meta.get("captured_at")
  if captured_at == nil || captured_at == "" {
    throw "check_fixture_staleness: metadata missing captured_at"
  }
  const age_days = _fixture_age_days(harness, captured_at)
  const upstream_url = meta.get("upstream_url") ?? "unknown upstream"
  const branch = _current_branch(harness)
  harness.stdio.println("fixture captured_at: ${captured_at}")
  harness.stdio.println("fixture upstream: ${upstream_url}")
  harness.stdio.println("fixture age: ${age_days} days")
  if age_days < _WARN_AFTER_DAYS {
    harness.stdio.println("fixture staleness: ok")
    return
  }
  if age_days < _FAIL_AFTER_DAYS {
    harness.stdio.println(
      "::warning title=Notion OpenAPI fixture stale::Pinned fixture is ${age_days} days old; run scripts/refresh_fixtures.harn and review scripts/fixture_diff.harn output.",
    )
    return
  }
  const message = "Pinned Notion OpenAPI fixture is " + to_string(age_days)
    + " days old; refresh it or file a periodic refresh issue."
  if branch == "main" {
    harness.stdio.println("::warning title=Notion OpenAPI fixture expired::${message}")
    harness.stdio.println("fixture staleness: expired on main, warning only")
    return
  }
  throw "check_fixture_staleness: " + message
}
