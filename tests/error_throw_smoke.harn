// error_throw_smoke — verify that generated SDK functions throw a
// structured dict (not a string) on non-2xx HTTP responses, so callers
// can pattern-match on shared connector error envelopes without parsing
// strings.
import { codegen_module, parse } from "../src/lib"

fn harn_cmd(harness: Harness, args: string) -> string {
  const bin = harness.env.get("HARN_BIN")
  if bin != nil && bin != "" {
    return bin + " " + args
  }
  return "harn " + args
}

fn scratch_path(harness: Harness, label: string) -> string {
  const root = source_dir() + "/../.harn/tmp"
  harness.fs.mkdir(root)
  return root + "/" + label + "-" + uuid()
}

fn build_doc() -> string {
  return json_stringify(
    {
      openapi: "3.1.0",
      info: {title: "Throw Test", version: "0.0.1"},
      servers: [{url: "https://api.example.com"}],
      paths: {
        "/v1/thing": {get: {operationId: "get-thing", responses: {"200": {description: "ok"}}}},
      },
      components: {securitySchemes: {bearerAuth: {type: "http", scheme: "bearer"}}},
      security: [{bearerAuth: []}],
    },
  )
}

@test
pipeline test_main() {
  const src = codegen_module(parse(build_doc()), {module_name: "throw_t", client_name: "T"})
  // The default transport should throw the shared connector envelope and
  // must NOT emit the legacy string format.
  assert(
    contains(src, "connector_http_request("),
    "default generated source must use connector transport",
  )
  assert(contains(src, "throw resp"), "generated source must throw the connector envelope")
  assert(
    !contains(src, "throw \"get_thing: HTTP \""),
    "legacy string-throw format must be gone for non-2xx responses",
  )
  // Drive the generated function against a mocked 404 and assert the
  // thrown payload's shape.
  const module_stem = scratch_path(harness, "harn-openapi-error-throw-smoke")
  const module_path = module_stem + ".harn"
  const runner_path = scratch_path(harness, "harn-openapi-error-throw-runtime") + ".harn"
  harness.fs.write_text(module_path, src)
  const body_lit = "{\"code\":\"not_found\",\"message\":\"missing\"}"
  const runner = "import { new_client, get_thing } from \"" + module_stem + "\"\n"
    + "\n"
    + "@test\n"
    + "pipeline default() {\n"
    + "  egress_policy({allow: [\"api.example.com\"], default: \"deny\"})\n"
    + "  http_mock_clear()\n"
    + "  http_mock(\"GET\", \"https://api.example.com/v1/thing\", "
    + "{status: 404, body: "
    + json_stringify(body_lit)
    + ", "
    + "headers: {\"x-request-id\": \"req-123\", \"content-type\": \"application/json\"}})\n"
    + "  let client = new_client(\"https://api.example.com\", \"tok\")\n"
    + "  let caught = try { get_thing(client); nil } catch (e) { e }\n"
    + "  assert(type_of(caught) == \"dict\", \"expected dict throw\")\n"
    + "  assert_eq(caught.operation, \"get_thing\")\n"
    + "  assert_eq(caught.status, 404)\n"
    + "  assert_eq(caught.category, \"not_found\")\n"
    + "  assert_eq(caught.ok, false)\n"
    + "  assert_eq(caught.body, "
    + json_stringify(body_lit)
    + ")\n"
    + "  assert_eq(type_of(caught.headers), \"dict\")\n"
    + "  assert_eq(caught.headers[\"x-request-id\"], \"req-123\")\n"
    + "  harness.stdio.println(\"error_throw runtime: ok\")\n"
    + "}\n"
  harness.fs.write_text(runner_path, runner)
  const result = shell(harn_cmd(harness, "run " + runner_path))
  if !result.success {
    harness.stdio.println("---runtime stderr---")
    harness.stdio.println(result.stderr)
    harness.stdio.println("---runtime stdout---")
    harness.stdio.println(result.stdout)
  }
  assert(result.success, "generated SDK must throw a dict on 404")
  harness.stdio.println("error_throw_smoke: ok")
}
