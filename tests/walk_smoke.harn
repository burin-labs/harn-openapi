// walk_smoke — M2 acceptance: enumerate operations, resolve the
// databases.query request body schema, print its property names, and
// exercise enum_values() on a known enum schema.
import { enum_values, operations, parse, schema } from "../src/lib"

pipeline test_main() {
  const raw = harness.fs.read_text(source_dir() + "/fixtures/notion.openapi.json")
  const doc = parse(raw)
  const ops = operations(doc)
  harness.stdio.println("operation count: ${len(ops)}")
  // Locate the query-a-data-source operation. Notion 2025-11 renamed
  // the classic "databases.query" endpoint to the data-sources URL,
  // so we look up the operation_id instead of the path.
  let query_op = nil
  for op in ops {
    if op.operation_id == "post-database-query" {
      query_op = op
    }
  }
  assert(query_op != nil, "could not find post-database-query operation")
  harness.stdio.println("query op: ${query_op.method} ${query_op.path}")
  const body_schema_raw = query_op.request_body.content["application/json"].schema
  const resolved = schema(doc, body_schema_raw)
  const fields = resolved.properties.keys()
  fields.sort()
  harness.stdio.println("request body fields (${len(fields)}):")
  for f in fields {
    harness.stdio.println("  - ${f}")
  }
  assert(fields.contains("filter"), "expected 'filter' field on query request body")
  // Find any schema with an enum and verify enum_values returns a list.
  let enum_name = ""
  let enum_size = 0
  const component_schemas = doc.components?.schemas ?? {}
  for entry in component_schemas {
    if enum_name == "" {
      const vs = enum_values(entry.value) ?? []
      if len(vs) > 0 {
        enum_name = entry.key
        enum_size = len(vs)
      }
    }
  }
  assert(enum_name != "", "expected at least one enum schema in fixture")
  harness.stdio.println("enum example '${enum_name}': ${enum_size} values")
  // Sanity-check that enum_values on a non-enum schema returns nil.
  assert(enum_values({type: "object"}) == nil, "enum_values on non-enum must return nil")
  harness.stdio.println("walk_smoke: ok")
}
