// codegen_smoke — M3 acceptance: generate a Harn SDK module from the
// pinned Notion fixture, write it out, and shell out to `harn check`
// to assert the emitted source parses cleanly.
import { codegen_module, parse } from "../src/lib"

fn harn_cmd(harness: Harness, args: string) -> string {
  const bin = harness.env.get("HARN_BIN")
  if bin != nil && bin != "" {
    return bin + " " + args
  }
  return "harn " + args
}

pipeline test_main() {
  const raw = harness.fs.read_text(source_dir() + "/fixtures/notion.openapi.json")
  const doc = parse(raw)
  const src = codegen_module(
    doc,
    {
      module_name: "notion",
      client_name: "NotionClient",
      default_base_url: "https://api.notion.com",
      header_overrides: {"Notion-Version": "2025-09-03"},
    },
  )
  const out_path = harness.fs.temp_dir() + "/harn-openapi-codegen-smoke-" + uuid() + ".harn"
  harness.fs.write_text(out_path, src)
  harness.stdio.println("wrote generated module: ${out_path} (${len(src)} bytes)")
  const cmd = harn_cmd(harness, "check " + out_path)
  const result = shell(cmd)
  if !result.success {
    harness.stdio.println("harn check stderr:")
    harness.stdio.println(result.stderr)
    harness.stdio.println("harn check stdout:")
    harness.stdio.println(result.stdout)
  }
  assert(result.success, "generated SDK must pass `harn check` (status ${result.status})")
  const fmt_cmd = harn_cmd(harness, "fmt --check " + out_path)
  const fmt_result = shell(fmt_cmd)
  if !fmt_result.success {
    harness.stdio.println("harn fmt --check stderr:")
    harness.stdio.println(fmt_result.stderr)
    harness.stdio.println("harn fmt --check stdout:")
    harness.stdio.println(fmt_result.stdout)
  }
  assert(
    fmt_result.success,
    "generated SDK must pass `harn fmt --check` (status ${fmt_result.status})",
  )
  harness.stdio.println("codegen_smoke: ok")
}
