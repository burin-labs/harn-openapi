// parse_smoke — M1 acceptance: parse the pinned Notion OpenAPI
// fixture and assert the doc looks plausible.
//
// The fixture is refreshed manually via scripts/refresh_fixtures.harn.
// Keep it pinned — do not auto-refresh.
import { operations, parse } from "../src/lib"

pipeline test_main() {
  const raw = harness.fs.read_text(source_dir() + "/fixtures/notion.openapi.json")
  const doc = parse(raw)
  assert(starts_with(doc.openapi, "3.1"), "openapi version must be 3.1.x")
  assert(contains(doc.info.title, "Notion"), "info.title must contain 'Notion'")
  const ops = operations(doc)
  const op_count = len(ops)
  harness.stdio.println("operations: ${op_count}")
  assert(op_count > 40, "expected >40 operations in the Notion fixture, got ${op_count}")
  const components = doc.components
  assert(components != nil, "doc.components must be present")
  const schemas = components.schemas
  assert(schemas != nil, "doc.components.schemas must be present")
  const schema_count = len(schemas)
  harness.stdio.println("schemas: ${schema_count}")
  assert(schema_count > 100, "expected >100 component schemas")
  harness.stdio.println("parse_smoke: ok")
}
