/* Smoke coverage for the harn-cli workflow version bump helper. */
fn harn_cmd(harness: Harness, args: string) -> string {
  const bin = harness.env.get("HARN_BIN")
  if bin != nil && bin != "" {
    return bin + " " + args
  }
  return "harn " + args
}

fn sh_quote(value: string) -> string {
  return "'" + replace(value, "'", "'\"'\"'") + "'"
}

fn cat_file(harness: Harness, path: string) -> string {
  return harness.fs.read_text(path)
}

pipeline test_main() {
  const repo_root = source_dir() + "/.."
  const fake_root = repo_root + "/.harn/tmp/harn-openapi-bump-smoke-" + uuid()
  harness.fs.mkdir(fake_root)
  harness.fs.write_text(fake_root + "/.harn-version", "0.0.1\n")
  const cmd = harn_cmd(
    harness,
    "run "
      + sh_quote(repo_root + "/scripts/bump_harn_cli_version.harn")
      + " -- v9.8.7 --repo-root "
      + sh_quote(fake_root)
      + " --no-verify",
  )
  const result = shell(cmd)
  if !result.success {
    harness.stdio.println(result.stderr)
    harness.stdio.println(result.stdout)
  }
  assert(result.success, "bump_harn_cli_version.harn must run")
  assert(contains(result.stdout, "0.0.1 -> 9.8.7"), "script should report version update")
  assert(contains(result.stdout, "skipped verification"), "test path should skip the full gate")
  const version = cat_file(harness, fake_root + "/.harn-version")
  assert_eq(version, "9.8.7\n")
  harness.fs.delete(fake_root)
  harness.stdio.println("bump_harn_cli_version_smoke: ok")
}
