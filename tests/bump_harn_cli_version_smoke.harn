/* Smoke coverage for the harn-cli workflow version bump helper. */
fn harn_cmd(args: string) -> string {
  let bin = env("HARN_BIN")
  if bin != nil && bin != "" {
    return bin + " " + args
  }
  return "harn " + args
}

fn sh_quote(value: string) -> string {
  return "'" + replace(value, "'", "'\"'\"'") + "'"
}

fn cat_file(path: string) -> string {
  let result = shell("cat " + sh_quote(path))
  if !result.success {
    println(result.stderr)
  }
  require result.success, "must read " + path
  return result.stdout
}

pipeline test_main() {
  let repo_root = source_dir() + "/.."
  let fake_root = temp_dir() + "/harn-openapi-bump-smoke-" + uuid()
  mkdir(fake_root)
  write_file(fake_root + "/.harn-version", "0.0.1\n")
  let cmd = harn_cmd(
    "run "
      + sh_quote(repo_root + "/scripts/bump_harn_cli_version.harn")
      + " -- v9.8.7 --repo-root "
      + sh_quote(fake_root)
      + " --no-verify",
  )
  let result = shell(cmd)
  if !result.success {
    println(result.stderr)
    println(result.stdout)
  }
  assert(result.success, "bump_harn_cli_version.harn must run")
  assert(contains(result.stdout, "0.0.1 -> 9.8.7"), "script should report version update")
  assert(contains(result.stdout, "skipped verification"), "test path should skip the full gate")
  let version = cat_file(fake_root + "/.harn-version")
  assert_eq(version, "9.8.7\n")
  println("bump_harn_cli_version_smoke: ok")
}
