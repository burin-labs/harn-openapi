// security_smoke — exercise per-scheme auth helpers emitted by
// codegen_module against synthetic OpenAPI docs. Each sub-scenario
// asserts the generated Harn source contains the correct auth-dispatch
// wiring and that the corresponding helper functions produce the
// expected Authorization / header / query bindings at runtime.
import { codegen_module, parse } from "../src/lib"

fn harn_cmd(harness: Harness, args: string) -> string {
  const bin = harness.env.get("HARN_BIN")
  if bin != nil && bin != "" {
    return bin + " " + args
  }
  return "harn " + args
}

fn scratch_path(harness: Harness, label: string) -> string {
  const root = source_dir() + "/../.harn/tmp"
  harness.fs.mkdir(root)
  return root + "/" + label + "-" + uuid()
}

fn build_doc(sec_schemes: dict, doc_security, ops: list) -> string {
  let paths = {}
  for op in ops {
    let method_entry = {operationId: op.operation_id, responses: {"200": {description: "ok"}}}
    if op.get("security") != nil {
      method_entry = {...method_entry, security: op.security}
    }
    paths = {...paths, [op.path]: {[op.method]: method_entry}}
  }
  let root = {
    openapi: "3.1.0",
    info: {title: "Test", version: "0.0.1"},
    servers: [{url: "https://api.example.com"}],
    paths: paths,
    components: {securitySchemes: sec_schemes},
  }
  if doc_security != nil {
    root = {...root, security: doc_security}
  }
  return json_stringify(root)
}

fn require_contains(harness: Harness, haystack: string, needle: string, label: string) {
  if !contains(haystack, needle) {
    harness.stdio.println("---BEGIN GENERATED SOURCE---")
    harness.stdio.println(haystack)
    harness.stdio.println("---END GENERATED SOURCE---")
    require false, "${label}: expected source to contain \"${needle}\""
  }
}

fn require_not_contains(harness: Harness, haystack: string, needle: string, label: string) {
  if contains(haystack, needle) {
    harness.stdio.println("---BEGIN GENERATED SOURCE---")
    harness.stdio.println(haystack)
    harness.stdio.println("---END GENERATED SOURCE---")
    require false, "${label}: expected source NOT to contain \"${needle}\""
  }
}

fn check_generates(harness: Harness, src: string, label: string) {
  const tmp_path = scratch_path(harness, "harn-openapi-security-smoke-${label}") + ".harn"
  harness.fs.write_text(tmp_path, src)
  const result = shell(harn_cmd(harness, "check " + tmp_path))
  if !result.success {
    harness.stdio.println("---harn check stderr---")
    harness.stdio.println(result.stderr)
    harness.stdio.println("---harn check stdout---")
    harness.stdio.println(result.stdout)
  }
  require result.success, "${label}: generated SDK must pass \\`harn check\\`"
  const fmt_result = shell(harn_cmd(harness, "fmt --check " + tmp_path))
  if !fmt_result.success {
    harness.stdio.println("---harn fmt --check stderr---")
    harness.stdio.println(fmt_result.stderr)
    harness.stdio.println("---harn fmt --check stdout---")
    harness.stdio.println(fmt_result.stdout)
  }
  require fmt_result.success, "${label}: generated SDK must pass \\`harn fmt --check\\`"
}

fn run_generated(harness: Harness, src: string, label: string, imports: string, body: string) {
  const module_stem = scratch_path(harness, "harn-openapi-security-smoke-${label}")
  const module_path = module_stem + ".harn"
  const runner_path = scratch_path(harness, "harn-openapi-security-runtime-${label}") + ".harn"
  harness.fs.write_text(module_path, src)
  harness.fs
    .write_text(
    runner_path,
    "import { "
      + imports
      + " } from \""
      + module_stem
      + "\"\n\npipeline default() {\n  egress_policy({allow: [\"api.example.com\"], default: \"deny\"})\n"
      + body
      + "\n}\n",
  )
  const result = shell(harn_cmd(harness, "run " + runner_path))
  if !result.success {
    harness.stdio.println("---${label} runtime stderr---")
    harness.stdio.println(result.stderr)
    harness.stdio.println("---${label} runtime stdout---")
    harness.stdio.println(result.stdout)
  }
  require result.success, "${label}: generated SDK runtime auth assertions must pass"
}

@test
pipeline test_main() {
  // ------------------------------------------------------------------
  // Scenario A: http bearer at the doc level, inherited by all ops.
  // ------------------------------------------------------------------
  const doc_a = build_doc(
    {bearerAuth: {type: "http", scheme: "bearer"}},
    [{bearerAuth: []}],
    [{operation_id: "get-self", method: "get", path: "/v1/users/me"}],
  )
  const src_a = codegen_module(parse(doc_a), {module_name: "a", client_name: "A"})
  require_contains(harness, src_a, "_headers_bearer_auth(client)", "A/dispatch")
  require_contains(harness, src_a, "Authorization: \"Bearer \" + token", "A/bearer-helper")
  require_contains(harness, src_a, "token: string = \"\"", "A/client-has-token")
  require_contains(harness, src_a, "token_provider = nil", "A/client-has-token-provider")
  require_not_contains(harness, src_a, "basic_user: string", "A/no-basic-field")
  require_not_contains(harness, src_a, "api_keys: dict", "A/no-apikey-field")
  check_generates(harness, src_a, "A")
  run_generated(
    harness,
    src_a,
    "A",
    "new_client, get_self",
    """
      http_mock_clear()
      http_mock("GET", "https://api.example.com/v1/users/me", {status: 200, body: "{}", headers: {}})
      let client = new_client("https://api.example.com", "bearer-token")
      get_self(client)
      let call = http_mock_calls({include_sensitive: true})[0]
      assert_eq(call.headers.authorization, "Bearer bearer-token")
    """,
  )
  run_generated(
    harness,
    src_a,
    "A-empty-token",
    "new_client, get_self",
    """
      http_mock_clear()
      http_mock("GET", "https://api.example.com/v1/users/me", {status: 200, body: "{}", headers: {}})
      let client = new_client("https://api.example.com")
      get_self(client)
      let call = http_mock_calls({include_sensitive: true})[0]
      assert_eq(call.headers.get("authorization"), nil)
    """,
  )
  // ------------------------------------------------------------------
  // Scenario B: explicit security: [] on one op overrides doc default.
  // ------------------------------------------------------------------
  const doc_b = build_doc(
    {bearerAuth: {type: "http", scheme: "bearer"}},
    [{bearerAuth: []}],
    [
      {operation_id: "get-self", method: "get", path: "/v1/users/me"},
      {operation_id: "public-ping", method: "get", path: "/health", security: []},
    ],
  )
  const src_b = codegen_module(parse(doc_b), {module_name: "b", client_name: "B"})
  // Authed op still uses the bearer helper.
  require_contains(harness, src_b, "_headers_bearer_auth(client)", "B/authed-dispatch")
  // The no-auth op must route through _no_auth_headers.
  const b_lines = split(src_b, "\n")
  let b_public_line = ""
  let b_collect_public = false
  for line in b_lines {
    if contains(line, "pub fn public_ping") {
      b_collect_public = true
    }
    if b_collect_public {
      if contains(line, "let request_headers = ") {
        b_public_line = line
        b_collect_public = false
      }
    }
  }
  assert(
    contains(b_public_line, "_no_auth_headers(client)"),
    "B/public-op-must-use-no-auth-headers: got \"${b_public_line}\"",
  )
  assert(
    !contains(b_public_line, "_headers_bearer_auth"),
    "B/public-op-must-NOT-use-bearer-helper: got \"${b_public_line}\"",
  )
  check_generates(harness, src_b, "B")
  run_generated(
    harness,
    src_b,
    "B",
    "new_client, get_self, public_ping",
    """
      http_mock_clear()
      http_mock("GET", "https://api.example.com/v1/users/me", {status: 200, body: "{}", headers: {}})
      http_mock("GET", "https://api.example.com/health", {status: 200, body: "{}", headers: {}})
      let client = new_client("https://api.example.com", "bearer-token")
      get_self(client)
      public_ping(client)
      let calls = http_mock_calls({include_sensitive: true})
      assert_eq(calls[0].headers.authorization, "Bearer bearer-token")
      assert_eq(calls[1].headers.get("authorization"), nil)
    """,
  )
  // ------------------------------------------------------------------
  // Scenario C: http basic only.
  // ------------------------------------------------------------------
  const doc_c = build_doc(
    {basicAuth: {type: "http", scheme: "basic"}},
    [{basicAuth: []}],
    [{operation_id: "login", method: "post", path: "/login"}],
  )
  const src_c = codegen_module(parse(doc_c), {module_name: "c", client_name: "C"})
  require_contains(harness, src_c, "_headers_basic_auth(client)", "C/dispatch")
  require_contains(harness, src_c, "base64_encode", "C/basic-uses-base64")
  require_contains(harness, src_c, "Authorization: \"Basic \" + encoded", "C/basic-header")
  require_contains(harness, src_c, "basic_user: string = \"\"", "C/client-has-basic-user")
  require_contains(harness, src_c, "basic_password: string = \"\"", "C/client-has-basic-password")
  require_not_contains(harness, src_c, "token: string", "C/no-token-field")
  check_generates(harness, src_c, "C")
  run_generated(
    harness,
    src_c,
    "C",
    "new_client, login",
    """
      http_mock_clear()
      http_mock("POST", "https://api.example.com/login", {status: 200, body: "{}", headers: {}})
      let client = new_client("https://api.example.com", "basic-user", "basic-pass")
      login(client)
      let call = http_mock_calls({include_sensitive: true})[0]
      assert_eq(call.headers.authorization, "Basic YmFzaWMtdXNlcjpiYXNpYy1wYXNz")
    """,
  )
  // ------------------------------------------------------------------
  // Scenario D: apiKey in header.
  // ------------------------------------------------------------------
  const doc_d = build_doc(
    {xApiKey: {type: "apiKey", in: "header", name: "X-Api-Key"}},
    [{xApiKey: []}],
    [{operation_id: "get-thing", method: "get", path: "/thing"}],
  )
  const src_d = codegen_module(parse(doc_d), {module_name: "d", client_name: "D"})
  require_contains(harness, src_d, "_headers_x_api_key(client)", "D/dispatch")
  require_contains(harness, src_d, "\"X-Api-Key\":", "D/header-name-emitted")
  require_contains(harness, src_d, "_client_api_key(client, \"xApiKey\")", "D/reads-from-api-keys")
  require_contains(harness, src_d, "api_keys: dict = {}", "D/client-has-api-keys")
  require_contains(harness, src_d, "api_key_provider = nil", "D/client-has-api-key-provider")
  require_not_contains(harness, src_d, "token: string", "D/no-token-field")
  check_generates(harness, src_d, "D")
  run_generated(
    harness,
    src_d,
    "D",
    "new_client, get_thing",
    """
      http_mock_clear()
      http_mock("GET", "https://api.example.com/thing", {status: 200, body: "{}", headers: {}})
      let client = new_client("https://api.example.com", {xApiKey: "header-key"})
      get_thing(client)
      let call = http_mock_calls({include_sensitive: true})[0]
      assert_eq(call.headers["x-api-key"], "header-key")
    """,
  )
  // ------------------------------------------------------------------
  // Scenario E: apiKey in query.
  // ------------------------------------------------------------------
  const doc_e = build_doc(
    {qKey: {type: "apiKey", in: "query", name: "api_key"}},
    [{qKey: []}],
    [{operation_id: "list-things", method: "get", path: "/things"}],
  )
  const src_e = codegen_module(parse(doc_e), {module_name: "e", client_name: "E"})
  require_contains(harness, src_e, "_headers_q_key(client)", "E/headers-dispatch")
  require_contains(harness, src_e, "_query_q_key_dict(client)", "E/query-spread-in-op")
  require_contains(harness, src_e, "api_key: v", "E/query-name-emitted")
  require_contains(harness, src_e, "_query_string", "E/op-has-query-string-call")
  check_generates(harness, src_e, "E")
  run_generated(
    harness,
    src_e,
    "E",
    "new_client, list_things",
    """
      http_mock_clear()
      http_mock("GET", "https://api.example.com/things?api_key=query-key", {status: 200, body: "{}", headers: {}})
      let client = new_client("https://api.example.com", {qKey: "query-key"})
      list_things(client)
      let call = http_mock_calls({include_sensitive: true})[0]
      assert_eq(call.url, "https://api.example.com/things?api_key=query-key")
    """,
  )
  // ------------------------------------------------------------------
  // Scenario F: apiKey in cookie.
  // ------------------------------------------------------------------
  const doc_f = build_doc(
    {sessId: {type: "apiKey", in: "cookie", name: "sid"}},
    [{sessId: []}],
    [{operation_id: "me", method: "get", path: "/me"}],
  )
  const src_f = codegen_module(parse(doc_f), {module_name: "f", client_name: "F"})
  require_contains(harness, src_f, "_headers_sess_id(client)", "F/dispatch")
  require_contains(harness, src_f, "_append_cookie_header(hs, \"sid\", api_key)", "F/cookie-header")
  require_contains(harness, src_f, "_client_api_key(client, \"sessId\")", "F/reads-from-api-keys")
  check_generates(harness, src_f, "F")
  run_generated(
    harness,
    src_f,
    "F",
    "new_client, me",
    """
      http_mock_clear()
      http_mock("GET", "https://api.example.com/me", {status: 200, body: "{}", headers: {}})
      let client = new_client("https://api.example.com", {sessId: "cookie key;admin=true"})
      me(client)
      let call = http_mock_calls({include_sensitive: true})[0]
      assert_eq(call.headers.cookie, "sid=cookie%20key%3Badmin%3Dtrue")
    """,
  )
  // ------------------------------------------------------------------
  // Scenario G: oauth2 — treated as bearer for v0 (client already holds token).
  // ------------------------------------------------------------------
  const doc_g = build_doc(
    {
      oauth2Auth: {
        type: "oauth2",
        flows: {clientCredentials: {tokenUrl: "https://api.example.com/oauth/token", scopes: {}}},
      },
    },
    [{oauth2Auth: []}],
    [{operation_id: "do-thing", method: "get", path: "/thing"}],
  )
  const src_g = codegen_module(parse(doc_g), {module_name: "g", client_name: "G"})
  require_contains(harness, src_g, "_headers_oauth2_auth(client)", "G/dispatch")
  require_contains(harness, src_g, "Authorization: \"Bearer \" + token", "G/bearer-shape")
  require_contains(harness, src_g, "token: string = \"\"", "G/client-has-token")
  require_contains(harness, src_g, "token_provider = nil", "G/client-has-token-provider")
  check_generates(harness, src_g, "G")
  run_generated(
    harness,
    src_g,
    "G",
    "new_client, do_thing",
    """
      http_mock_clear()
      http_mock("GET", "https://api.example.com/thing", {status: 200, body: "{}", headers: {}})
      let client = new_client("https://api.example.com", "oauth-token")
      do_thing(client)
      let call = http_mock_calls({include_sensitive: true})[0]
      assert_eq(call.headers.authorization, "Bearer oauth-token")
    """,
  )
  // ------------------------------------------------------------------
  // Scenario H: mixed schemes (bearer + basic) with per-op overrides,
  // mirroring the real-world Notion shape.
  // ------------------------------------------------------------------
  const doc_h = build_doc(
    {bearerAuth: {type: "http", scheme: "bearer"}, basicAuth: {type: "http", scheme: "basic"}},
    [{bearerAuth: []}],
    [
      {operation_id: "get-me", method: "get", path: "/v1/users/me"},
      {
        operation_id: "create-a-token",
        method: "post",
        path: "/v1/oauth/token",
        security: [{basicAuth: []}],
      },
    ],
  )
  const src_h = codegen_module(parse(doc_h), {module_name: "h", client_name: "H"})
  // Bearer helper defined and used by the default op.
  require_contains(harness, src_h, "fn _headers_bearer_auth(", "H/bearer-helper-defined")
  require_contains(harness, src_h, "fn _headers_basic_auth(", "H/basic-helper-defined")
  // Check per-op dispatch line by line.
  const h_lines = split(src_h, "\n")
  let h_get_me_line = ""
  let h_token_line = ""
  let h_collect_me = false
  let h_collect_token = false
  for line in h_lines {
    if contains(line, "pub fn get_me") {
      h_collect_me = true
    }
    if contains(line, "pub fn create_a_token") {
      h_collect_token = true
    }
    if h_collect_me && contains(line, "let request_headers = ") {
      h_get_me_line = line
      h_collect_me = false
    }
    if h_collect_token && contains(line, "let request_headers = ") {
      h_token_line = line
      h_collect_token = false
    }
  }
  assert(
    contains(h_get_me_line, "_headers_bearer_auth(client)"),
    "H/get_me-uses-bearer: got \"${h_get_me_line}\"",
  )
  assert(
    contains(h_token_line, "_headers_basic_auth(client)"),
    "H/create_a_token-uses-basic: got \"${h_token_line}\"",
  )
  assert(
    !contains(h_token_line, "_headers_bearer_auth"),
    "H/create_a_token-must-NOT-use-bearer: got \"${h_token_line}\"",
  )
  check_generates(harness, src_h, "H")
  // ------------------------------------------------------------------
  // Scenario I: mutualTLS — v0 fallback to no-auth with a NOTE comment.
  // ------------------------------------------------------------------
  const doc_i = build_doc(
    {mtls: {type: "mutualTLS"}},
    [{mtls: []}],
    [{operation_id: "mtls-op", method: "get", path: "/secure"}],
  )
  const src_i = codegen_module(parse(doc_i), {module_name: "i", client_name: "I"})
  require_contains(harness, src_i, "// NOTE: security scheme 'mtls'", "I/fallback-note-emitted")
  require_contains(harness, src_i, "_headers_mtls(client)", "I/fallback-helper-called")
  require_contains(harness, src_i, "return _no_auth_headers(client)", "I/falls-back-to-no-auth")
  check_generates(harness, src_i, "I")
  // ------------------------------------------------------------------
  // Scenario J: multiple security alternatives are preserved as a NOTE,
  // not a TODO, so generated code can be committed without open TODOs.
  // ------------------------------------------------------------------
  const doc_j = build_doc(
    {bearerAuth: {type: "http", scheme: "bearer"}, basicAuth: {type: "http", scheme: "basic"}},
    [{bearerAuth: []}, {basicAuth: []}],
    [{operation_id: "either-auth", method: "get", path: "/either"}],
  )
  const src_j = codegen_module(parse(doc_j), {module_name: "j", client_name: "J"})
  require_contains(
    harness,
    src_j,
    "NOTE: security alternatives also accepted: basicAuth",
    "J/security-alternative-note",
  )
  require_not_contains(harness, src_j, "TODO", "J/generated-source-has-no-todos")
  check_generates(harness, src_j, "J")
  harness.stdio.println("security_smoke: ok")
}
