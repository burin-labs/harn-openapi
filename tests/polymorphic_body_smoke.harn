// polymorphic_body_smoke — issue #3 acceptance: codegen detects
// oneOf/anyOf JSON request bodies, emits variant constructors, strips
// the internal _variant tag before sending, and respects discriminator
// mapping values as tags.
import { codegen_module, parse } from "../src/lib"

fn harn_cmd(harness: Harness, args: string) -> string {
  const bin = harness.env.get("HARN_BIN")
  if bin != nil && bin != "" {
    return bin + " " + args
  }
  return "harn " + args
}

fn scratch_path(harness: Harness, label: string) -> string {
  const root = source_dir() + "/../.harn/tmp"
  harness.fs.mkdir(root)
  return root + "/" + label + "-" + uuid()
}

const _POLY_DOC = """
  {
    "openapi": "3.1.0",
    "info": { "title": "Polymorphic API", "version": "1.0.0" },
    "servers": [{"url": "https://api.example.com"}],
    "paths": {
      "/pets/{pet_id}": {
        "patch": {
          "operationId": "update-pet",
          "parameters": [
            {"name": "pet_id", "in": "path", "required": true,
             "schema": {"type": "string"}}
          ],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {"$ref": "#/components/schemas/CatUpdate"},
                    {"$ref": "#/components/schemas/DogUpdate"}
                  ],
                  "discriminator": {
                    "propertyName": "kind",
                    "mapping": {
                      "cat": "#/components/schemas/CatUpdate",
                      "dog": "#/components/schemas/DogUpdate"
                    }
                  }
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "ok",
              "content": {"application/json": {"schema": {"type": "object"}}}
            }
          }
        }
      },
      "/shape": {
        "post": {
          "operationId": "submit-shape",
          "requestBody": {
            "content": {
              "application/json": {
                "schema": {
                  "anyOf": [
                    {
                      "title": "Circle Shape",
                      "type": "object",
                      "required": ["radius"],
                      "properties": {"radius": {"type": "number"}}
                    },
                    {
                      "title": "Square Shape",
                      "type": "object",
                      "required": ["side"],
                      "properties": {"side": {"type": "number"}}
                    }
                  ]
                }
              }
            }
          },
          "responses": {"204": {"description": "accepted"}}
        }
      }
    },
    "components": {
      "schemas": {
        "CatUpdate": {
          "type": "object",
          "required": ["kind", "meow"],
          "properties": {
            "kind": {"type": "string", "const": "cat"},
            "meow": {"type": "string"},
            "lives": {"type": "integer"}
          }
        },
        "DogUpdate": {
          "type": "object",
          "required": ["kind", "bark"],
          "properties": {
            "kind": {"type": "string", "const": "dog"},
            "bark": {"type": "boolean"}
          }
        }
      }
    }
  }
  """

fn count_occurrences(haystack: string, needle: string) -> int {
  let count = 0
  let idx = 0
  const hn = len(haystack)
  const nn = len(needle)
  if nn == 0 {
    return 0
  }
  while idx + nn <= hn {
    if substring(haystack, idx, idx + nn) == needle {
      count = count + 1
      idx = idx + nn
    } else {
      idx = idx + 1
    }
  }
  return count
}

fn require_contains(harness: Harness, haystack: string, needle: string, label: string) {
  if !contains(haystack, needle) {
    harness.stdio.println("---BEGIN GENERATED SOURCE---")
    harness.stdio.println(haystack)
    harness.stdio.println("---END GENERATED SOURCE---")
    require false, "${label}: expected generated source to contain ${needle}"
  }
}

fn check_file(harness: Harness, path: string, label: string) {
  const result = shell(harn_cmd(harness, "check " + path))
  if !result.success {
    harness.stdio.println("---${label} harn check stderr---")
    harness.stdio.println(result.stderr)
    harness.stdio.println("---${label} harn check stdout---")
    harness.stdio.println(result.stdout)
  }
  require result.success, "${label}: generated module must pass harn check"
}

fn run_file(harness: Harness, path: string, label: string) {
  const result = shell(harn_cmd(harness, "run " + path))
  if !result.success {
    harness.stdio.println("---${label} harn run stderr---")
    harness.stdio.println(result.stderr)
    harness.stdio.println("---${label} harn run stdout---")
    harness.stdio.println(result.stdout)
  }
  require result.success, "${label}: generated module runtime smoke must pass"
}

pipeline test_main() {
  const doc = parse(_POLY_DOC)
  const src = codegen_module(
    doc,
    {
      module_name: "poly",
      client_name: "PolyClient",
      default_base_url: "https://api.example.com",
      header_overrides: {},
    },
  )
  const module_stem = scratch_path(harness, "harn-openapi-polymorphic-generated")
  const out_path = module_stem + ".harn"
  harness.fs.write_text(out_path, src)
  require_contains(
    harness,
    src,
    "pub fn update_pet(client: dict, pet_id, body) -> dict",
    "umbrella",
  )
  require_contains(
    harness,
    src,
    "pub fn update_pet_cat_update(meow: string, lives = nil) -> dict",
    "cat ctor",
  )
  require_contains(harness, src, "pub fn update_pet_dog_update(bark: bool) -> dict", "dog ctor")
  require_contains(
    harness,
    src,
    "if ![\"cat\", \"dog\"].contains(body_variant)",
    "discriminator tags",
  )
  require_contains(harness, src, "kind: \"cat\"", "cat const discriminator")
  require_contains(harness, src, "_variant: \"cat\"", "cat internal tag")
  require_contains(
    harness,
    src,
    "pub fn submit_shape_circle_shape(radius: float) -> dict",
    "anyOf ctor",
  )
  require_contains(
    harness,
    src,
    "pub fn submit_shape_square_shape(side: float) -> dict",
    "anyOf ctor",
  )
  check_file(harness, out_path, "poly")
  const runner_path = scratch_path(harness, "harn-openapi-polymorphic-runner") + ".harn"
  harness.fs.write_text(
    runner_path,
    "import { new_client, update_pet, update_pet_cat_update } from \""
      + module_stem
      + "\"\n"
      + """

    pipeline default() {
      egress_policy({allow: ["api.example.com"], default: "deny"})
      http_mock_clear()
      http_mock("PATCH", "https://api.example.com/pets/p1", {
        status: 200,
        body: "{}",
        headers: {},
      })
      let client = new_client()
      let body = update_pet_cat_update("mew", 9)
      assert(body._variant == "cat", "constructor must tag cat body")
      update_pet(client, "p1", body)
      let calls = http_mock_calls()
      assert(len(calls) == 1, "expected one mocked call")
      let sent = json_parse(calls[0].body)
      assert(sent.kind == "cat", "outbound body keeps discriminator")
      assert(sent.meow == "mew", "outbound body keeps required field")
      assert(sent.lives == 9, "outbound body keeps optional field")
      assert(sent.get("_variant") == nil, "outbound body strips internal _variant")
    }
    """,
  )
  run_file(harness, runner_path, "poly")
  const notion_raw = harness.fs.read_text(source_dir() + "/fixtures/notion.openapi.json")
  const notion_src = codegen_module(
    parse(notion_raw),
    {
      module_name: "notion",
      client_name: "NotionClient",
      default_base_url: "https://api.notion.com",
      header_overrides: {"Notion-Version": "2025-09-03"},
    },
  )
  require_contains(
    harness,
    notion_src,
    """pub fn update_page_markdown(
  client: dict,
  page_id,
  body,
  notion_version = nil,
) -> PageMarkdownResponse""",
    "notion umbrella",
  )
  require_contains(
    harness,
    notion_src,
    "pub fn update_page_markdown_insert_content(insert_content: dict) -> dict",
    "notion insert_content ctor",
  )
  require_contains(
    harness,
    notion_src,
    "pub fn update_page_markdown_replace_content_range(replace_content_range: dict) -> dict",
    "notion replace_content_range ctor",
  )
  require_contains(
    harness,
    notion_src,
    "pub fn update_page_markdown_update_content(update_content: dict) -> dict",
    "notion update_content ctor",
  )
  require_contains(
    harness,
    notion_src,
    "pub fn update_page_markdown_replace_content(replace_content: dict) -> dict",
    "notion replace_content ctor",
  )
  const notion_ctors = count_occurrences(notion_src, "pub fn update_page_markdown_")
  assert(notion_ctors == 4, "expected four Notion markdown constructors, got ${notion_ctors}")
  require_contains(harness, notion_src, "_strip_codegen_variant(body)", "notion strips _variant")
  harness.stdio.println("polymorphic_body_smoke: ok")
}
